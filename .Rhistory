library(ggplot2)
library(dplyr)
# Quality control
S <- expand.grid(x1 = c("G","D"), x2 = c("G","D"),
x3 = c("G","D")) |>
mutate(omega = paste0(x1, x2, x3))
S <- S |> mutate(
A = (x1=="D") | (x2=="D") | (x3=="D"), # at least one defective
B = (x1=="D") + (x2=="D") + (x3=="D") == 1 # exactly one defective
)
S[, c("omega","A","B")]
S |>
mutate(defects = (x1=="D") + (x2=="D") + (x3=="D"
)) |>
count(defects) |>
ggplot(aes(x = defects, y = n)) +
geom_col() +
labs(title = "Number of defectives?",
x = "number of defectives in omega", y = "
count in S")
## de Morgan's law illustration
A <- S$A
B <- S$B
print(matrix(c(A, B), ncol = 2))
left <- !(A | B) # NOT(A OR B)
right <- (!A) & (!B) # (NOT A) AND (NOT B)
all(left == right) # TRUE means identity holds on every omega
dice <- expand.grid(d1 = 1:6, d2 = 1:6) |> mutate(
sum = d1 + d2,
A = (sum == 7), # sum is 7
B = (d1 == 6) | (d2 == 6)
)
ggplot(dice, aes(x = d1, y = d2)) +
geom_tile(aes(alpha = A), linewidth = 0.3) +
scale_x_continuous(breaks = 1:6) +
scale_y_continuous(breaks = 1:6) +
labs(title = "Two dice: 36 equally likely
outcomes (shade sum=7)",
x = "die 1", y = "die 2") +
guides(alpha = "none")
S[, c("omega","A","B")]
S |>
mutate(defects = (x1=="D") + (x2=="D") + (x3=="D"
)) |>
count(defects) |>
ggplot(aes(x = defects, y = n)) +
geom_col() +
labs(title = "Number of defectives?",
x = "number of defectives in omega", y = "
count in S")
## de Morgan's law illustration
A <- S$A
B <- S$B
print(matrix(c(A, B), ncol = 2))
left <- !(A | B) # NOT(A OR B)
right <- (!A) & (!B) # (NOT A) AND (NOT B)
all(left == right) # TRUE means identity holds on every omega
dice <- expand.grid(d1 = 1:6, d2 = 1:6) |> mutate(
sum = d1 + d2,
A = (sum == 7), # sum is 7
B = (d1 == 6) | (d2 == 6)
)
ggplot(dice, aes(x = d1, y = d2)) +
geom_tile(aes(alpha = A), linewidth = 0.3) +
scale_x_continuous(breaks = 1:6) +
scale_y_continuous(breaks = 1:6) +
labs(title = "Two dice: 36 equally likely
outcomes (shade sum=7)",
x = "die 1", y = "die 2") +
guides(alpha = "none")
sum_dist <- dice |> count(sum) |>
mutate(prob = n / sum(n))
ggplot(sum_dist, aes(x = sum, y = prob)) +
geom_col() +
scale_x_continuous(breaks = 2:12) +
labs(title = "Distribution of the sum of two dice
(not uniform!)",
x = "sum", y = "probability (count / 36)")
### Increasing monotone sequence
T <- 50
N <- 20000 # increase n so that empirical and theoretical probabilities align
X <- matrix(sample(c(0,1), N*T, replace=TRUE), nrow=N)  # 1=Head
Ak_prob <- sapply(1:T, function(k){
mean(rowSums(X[,1:k, drop=FALSE]) >= 1)
})
theory <- 1 - (1/2)^(1:T)
dfA <- tibble(k = 1:T, sim = Ak_prob, theory = theory)
ggplot(dfA, aes(x = k)) +
geom_line(aes(y = sim)) +
geom_line(aes(y = theory)) +
labs(title = "Increasing events Ak: P(at least one Head by time k)",
y = "probability", x = "k")
Bk_prob <- sapply(1:T, function(k){ mean(rowSums(X[,1:k, drop=FALSE]) == k)
})
theoryB <- (1/2)^(1:T)
dfB <- tibble(k = 1:T, sim = Bk_prob, theory = theoryB)
ggplot(dfB, aes(x = k)) +
geom_line(aes(y = sim)) +
geom_line(aes(y = theory)) +
labs(title = "Decreasing events Bk: P(all Heads
up to time k)",
y = "probability", x = "k")
# Count number of heads in last 10 tosses for each simulation
tail_heads <- rowSums(X[,(T-9):T, drop=FALSE])
# Look at lim Inf Cn approximation-> should be close to zero
mean(tail_heads == 10)
# Look at lim Sup Cn approximation
mean(rowSums(X) >= 20)
