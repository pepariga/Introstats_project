final_data_complete$affordability_gap,
names = c("HPI\n(House Prices)", "Wage\nGrowth", "Inflation\nRate", "Affordability\nGap"),
col = c("lightblue", "lightgreen", "pink", "orange"),
main = "Distribution of Economic Indicators (10-Year Period)",
ylab = "Percentage Change (%)",
las = 1,           # Čísla na ose Y budou čitelně rovně
cex.names = 0.9)   # Písmo dole se malinko zmenší, ať se tam vejde
