plot(final_data_complete$wage_growth,
final_data_complete$hpi_value,
main = "Relationship between Wage Growth and House Prices",
xlab = "Wage Growth (%)",
ylab = "House Price Index Growth (%)",
pch = 16,          # pch = 16 udělá plná kolečka (lépe to vypadá)
col = "darkblue",  # barva bodů
las = 1)           # čísla na ose Y budou čitelně rovně
