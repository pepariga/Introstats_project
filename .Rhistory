#boxplots
boxplot(final_data_complete$hpi_value,
final_data_complete$wage_growth,
final_data_complete$inflation_rate,
final_data_complete$affordability_gap,
names = c("HPI (Ceny domů)", "Mzdy", "Inflace", "Rozdíl (Gap)"),
col = c("lightblue", "lightgreen", "pink", "orange"),
main = "Základní rozložení hodnot a extrémy")
# Vykreslení grafu
ggplot(data_boxplot, aes(x = ukazatel, y = hodnota, fill = ukazatel)) +
geom_boxplot(outlier.colour = "red", outlier.size = 2) + # červené tečky jsou extrémy
theme_minimal() +
labs(title = "Rozložení hodnot a extrémy (červené tečky)",
x = "Ekonomický ukazatel",
y = "Procentní změna (%)") +
theme(legend.position = "none") # skryje legendu, protože názvy jsou už dole
boxplot(final_data_complete$hpi_value,
final_data_complete$wage_growth,
final_data_complete$inflation_rate,
final_data_complete$affordability_gap,
names = c("HPI", "Wage Growth", "Inflation", "Affordability Gap"),
col = c("lightblue", "lightgreen", "pink", "orange"),
main = "Distribution of Economic Indicators and Outliers",
ylab = "Percentage change (%)")
final_data_long <- final_data_complete %>%
pivot_longer(cols = c(hpi_value, wage_growth, inflation_rate, affordability_gap),
names_to = "variable",
values_to = "value") %>%
mutate(variable = recode(variable,
hpi_value = "HPI (Ceny domů)",
wage_growth = "Růst mezd",
inflation_rate = "Inflace",
affordability_gap = "Affordability Gap"))
boxplot_plot <- ggplot(final_data_long, aes(x = variable, y = value, fill = variable)) +
geom_boxplot(outlier.colour = "red", outlier.shape = 16, outlier.size = 2, alpha = 0.7) +
theme_minimal() +
labs(title = "Rozdělení hodnot a detekce odlehlých hodnot (Outliers)",
subtitle = "Červené body značí extrémní výkyvy v daných letech/zemích",
x = "Ekonomický ukazatel",
y = "Procentní změna (%)") +
theme(legend.position = "none")
print(boxplot_plot)
# (Volitelně pro uložení grafu: ggsave("boxploty.png", width = 8, height = 6))
