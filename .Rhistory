# c) Přidání trendové čáry (lineární regrese)
# Ukáže nám celkový směr, kterým data jdou
abline(lm(hpi_value ~ wage_growth, data = final_data_complete),
col = "red",
lwd = 2)         # lwd = 2 udělá čáru tlustší
# frequency table
inflation_freq <- final_data_complete %>%
mutate(Inflation_Category = case_when(
inflation_rate < 0 ~ "Deflation (<0%)",
inflation_rate >= 0 & inflation_rate <= 2 ~ "Ideal (0-2%)",
inflation_rate > 2 & inflation_rate <= 5 ~ "Elevated (2-5%)",
inflation_rate > 5 ~ "High (>5%)"
)) %>%
count(Inflation_Category, name = "Count")
print("--- Frequency Table for Inflation ---")
print(as.data.frame(inflation_freq))
