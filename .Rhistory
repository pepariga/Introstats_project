inflation_freq <- final_data_complete %>%
mutate(Inflation_Category = case_when(
inflation_rate < 0 ~ "1. Deflation (<0%)",
inflation_rate >= 0 & inflation_rate <= 2 ~ "2. Ideal (0-2%)",
inflation_rate > 2 & inflation_rate <= 5 ~ "3. Elevated (2-5%)",
inflation_rate > 5 & inflation_rate <= 10 ~ "4. High (5-10%)",
inflation_rate > 10 ~ "5. Extreme (>10%)"
)) %>%
count(Inflation_Category, name = "Count") %>%
mutate(Percentage = round((Count / sum(Count)) * 100, 1))
print("--- Frequency Table for Inflation ---")
print(as.data.frame(inflation_freq))
