hpi_value > 5 & hpi_value <= 10 ~ "3. High (5-10%)",
hpi_value > 10 ~ "4. Extreme (>10%)"
)) %>%
count(Category, name = "Count") %>%
mutate(Percentage = round((Count / sum(Count)) * 100, 1))
